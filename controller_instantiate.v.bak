module controller_instantiate (
	input CLOCK_50,
	input[3:0] KEY[3:0],
	output[6:0] HEX0[6:0],
	output[6:0] HEX1[6:0],
	output[6:0] HEX2[6:0],
	output[6:0] HEX3[6:0],
	output[6:0] HEX4[6:0],
	output[6:0] HEX5[6:0],
);

	// Synchronous falling edge detector for KEY3
	reg KEY3_d;
	wire rst;
	
	always @(posedge CLOCK_50) begin
		KEY3_d <= KEY[3];
	end
	
	assign rst = KEY3_d & ~KEY[3];
	
	// Synthetic 1S Clock
	reg[31:0] MHz_counter;
	reg CLOCK_1S;
	
	always @(posedge CLOCK_50, posedge rst) begin
		if (rst) begin
			MHz_counter = 0;
			CLOCK_1S = 0;
		end
	
		MHz_counter = MHz_counter + 1;
		
		if (MHz_counter == 25000000 - 1) begin
			CLOCK_1S <= ~CLOCK_1S;
			MHz_counter <= 0;
		end 
	end
	
	// controller setup
	wire r1, r2, r3;
	
	controller controller_inst(
		.clk(CLOCK_1S),
		.rst(rst),
		.start(),
		.pmem_in(),
		.pmem_write(),
		.r0_out(r1),
		.r1_out(r2),
		.r2_out(r3)
	);
	
	// display registers
	

endmodule